# ============================================================
# RideGuard - Environment Configuration Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to GitHub
# ============================================================

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# User Information
USER_NAME=Rider Name
VEHICLE_NUMBER=TN00XX0000
PHONE_NUMBER=+91XXXXXXXXXX

# Hardware Configuration
ESP32_IP=192.168.137.X
ESP32_STREAM_URL=http://192.168.137.X:81/stream
ARDUINO_PORT=COM16
ESP32_PORT=COM3

# Detection Thresholds
DIST_THRESHOLD=2
WARNING_THRESHOLD=6
TILT_THRESHOLD=10
CONFIRM_COUNT=3
TRIGGER_COOLDOWN=15

# GPS Configuration
GPS_LOG_INTERVAL=15

# Hotspot Detection (DBSCAN)
RISK_RADIUS=2.0
ACCIDENT_THRESHOLD=5
HOTSPOT_CHECK_INTERVAL=60
HOTSPOT_COOLDOWN=300
